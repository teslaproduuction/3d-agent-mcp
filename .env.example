# =============================================================================
# 3D Agent MCP - Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your API keys
# cp .env.example .env
#
# IMPORTANT: Never commit .env to git! It contains sensitive API keys.
#

# =============================================================================
# CLOUD LLM PROVIDERS (Required for agent orchestration)
# =============================================================================

# OpenAI API (for GPT-5 Mini, o3-mini, image generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API (for Claude Sonnet/Opus)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# 3D GENERATION PROVIDERS
# =============================================================================

# Tripo3D API (fast 3D generation, recommended)
# Get your key at: https://platform.tripo3d.ai/
TRIPO_API_KEY=your-tripo-api-key-here

# Meshy AI (optional, alternative 3D provider)
# Get your key at: https://www.meshy.ai/
MESHY_API_KEY=your-meshy-api-key-here

# =============================================================================
# IMAGE GENERATION PROVIDERS
# =============================================================================

# Replicate API (for SDXL, Flux, other image models)
# Get your key at: https://replicate.com/account
REPLICATE_API_TOKEN=r8_your-replicate-token-here

# Stability AI (optional, for Stable Diffusion models)
# Get your key at: https://platform.stability.ai/
STABILITY_API_KEY=sk-your-stability-api-key-here

# =============================================================================
# OPTIONAL: GOOGLE CLOUD (for Gemini models)
# =============================================================================

# Google Cloud API (for Gemini 2.0 Flash)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIza-your-google-api-key-here

# =============================================================================
# LOCAL MODEL CONFIGURATION
# =============================================================================

# Redis session store (state persists across reloads/restarts)
# Local dev: redis://localhost:6379  (default, Redis from docker-compose.dev.yml)
# Full Docker: redis://redis:6379    (set automatically in docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Session TTL in seconds (24 hours default)
REDIS_SESSION_TTL_SECONDS=86400

# Ollama Base URL (if running locally)
# Default: http://localhost:11434/v1
# Docker: http://ollama:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Qwen-Image-Edit URL (if running locally)
# Default: http://localhost:8001
# Docker: http://qwen-image-edit:8000
QWEN_IMAGE_URL=http://localhost:8001

# Trellis3D URL (if running locally)
# Default: http://localhost:8000
# Docker: http://trellis3d:8000
TRELLIS3D_URL=http://localhost:8000

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development/production)
ENVIRONMENT=development

# Gradio server settings
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Enable debug logging (true/false)
DEBUG=false

# Output directories (relative to project root)
OUTPUT_DIR=outputs
MODELS_DIR=outputs/models
IMAGES_DIR=outputs/images
PREVIEWS_DIR=outputs/previews
LOGS_DIR=outputs/logs

# =============================================================================
# NOTES
# =============================================================================
#
# Minimum required keys to get started:
# - OPENAI_API_KEY (for LLM and image generation)
# - ANTHROPIC_API_KEY (optional, for Claude models)
# - TRIPO_API_KEY (for 3D generation)
#
# Local-only setup (no API costs):
# - Run docker-compose up -d
# - Set OLLAMA_BASE_URL, QWEN_IMAGE_URL, TRELLIS3D_URL
# - Update config.yaml to use local providers
#
# Hybrid setup (recommended):
# - Use cloud APIs for LLM and 3D (faster, better quality)
# - Use local Qwen for image generation (privacy, no cost)
# - Set: OPENAI_API_KEY, TRIPO_API_KEY, QWEN_IMAGE_URL
#
